{
  "model": "gemini-2.0-flash-exp",
  "maxTokens": 8192,
  "temperature": 0.7,
  "purpose": "Research delegation to save Claude tokens",

  "instructions": {
    "master": "./GEMINI.md",
    "constraints": "./prompts/constraints.txt",
    "context": {
      "general": "./prompts/general-context.txt",
      "dndev": "./prompts/dndev-context.txt"
    }
  },

  "usage": {
    "goodFor": [
      "Research (docs, best practices, comparisons)",
      "Translations (i18n files)",
      "Document assessment (quality, completeness)",
      "Data extraction (specific info from large docs)"
    ],
    "badFor": [
      "Implementation (Claude does this)",
      "Strategic decisions (Claude does this)",
      "Codebase questions (Claude knows the code)",
      "Complex reasoning (Gemini is dumb)"
    ]
  },

  "problems": {
    "rambling": "Fixed by GEMINI.md length limits",
    "noMemory": "Accept it - each call is standalone",
    "offTarget": "Fixed by constraints.txt",
    "dumbDecisions": "Don't ask for decisions - just data"
  }
}
